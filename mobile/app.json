{
  "expo": {
    "name": "ResQNet",
    "slug": "resqnet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "resqnet",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.resqnet.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Location needed to send SOS and find nearby resources.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Background location allows mission tracking.",
        "NSBluetoothAlwaysUsageDescription": "Bluetooth used for mesh SOS relay when network is unavailable.",
        "NSBluetoothPeripheralUsageDescription": "Bluetooth used for mesh SOS relay."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.resqnet.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_ADVERTISE",
        "BLUETOOTH_CONNECT",
        "CAMERA"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "ResQNet needs location to send SOS and coordinate relief.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        { "cameraPermission": "Allow ResQNet to use camera for evidence capture." }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ef4444"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
